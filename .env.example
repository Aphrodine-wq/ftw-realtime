# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=ecto://postgres:postgres@localhost:5432/ftw_realtime_dev

# ── Auth ─────────────────────────────────────────────────────────
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret

# ── Server ───────────────────────────────────────────────────────
PHX_HOST=localhost
PHX_SERVER=true
PORT=4000
POOL_SIZE=10

# ── Admin Dashboard ──────────────────────────────────────────────
ADMIN_PASSWORD=faircommand

# ── Email (Swoosh SMTP) ─────────────────────────────────────────
# Leave unset for local adapter in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── File Storage (S3/R2) ────────────────────────────────────────
# Leave unset for local disk in dev
STORAGE_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
STORAGE_ENDPOINT=

# ── Verification ─────────────────────────────────────────────────
PERSONA_API_KEY=
CHECKR_API_KEY=

# ── AI (RunPod) ──────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ── Push Notifications (Expo) ────────────────────────────────────
EXPO_ACCESS_TOKEN=
